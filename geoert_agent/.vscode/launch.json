{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "🌍 Run Demo (Schlumberger · Sedimentary)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "args": [
        "--demo",
        "--array", "schlumberger",
        "--terrain", "sedimentary",
        "--site", "Demo Site — Sedimentary",
        "--output", "./output/demo_sed"
      ],
      "console": "integratedTerminal"
    },

    {
      "name": "🏔️ Run Demo (Wenner · Basement Complex)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "args": [
        "--demo",
        "--array", "wenner",
        "--terrain", "basement",
        "--site", "Demo Site — Basement Complex",
        "--output", "./output/demo_basement"
      ],
      "console": "integratedTerminal"
    },

    {
      "name": "📂 Run from CSV File",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "args": [
        "--file", "${input:csvPath}",
        "--array", "${input:arrayType}",
        "--terrain", "${input:terrainType}",
        "--site", "${input:siteName}",
        "--output", "./output/field"
      ],
      "console": "integratedTerminal"
    },

    {
      "name": "🤖 Start Telegram Bot",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "args": ["--bot"],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },

    {
      "name": "🧪 Run All Tests",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v", "--tb=short"],
      "console": "integratedTerminal"
    }

  ],

  "inputs": [
    {
      "id": "csvPath",
      "type": "promptString",
      "description": "Path to your CSV file",
      "default": "data/sample_data/schlumberger_sedimentary.csv"
    },
    {
      "id": "arrayType",
      "type": "pickString",
      "description": "Electrode array type",
      "options": ["schlumberger", "wenner", "dipole_dipole"],
      "default": "schlumberger"
    },
    {
      "id": "terrainType",
      "type": "pickString",
      "description": "Terrain type",
      "options": ["sedimentary", "basement"],
      "default": "sedimentary"
    },
    {
      "id": "siteName",
      "type": "promptString",
      "description": "Survey site name",
      "default": "My Survey Site"
    }
  ]
}
